# Update these with your Supabase details from your project settings > API
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# Server-only: required for admin "Invite user" (auth.admin.inviteUserByEmail)
# https://app.supabase.com/project/_/settings/api — service_role key (never expose to client)
SUPABASE_SERVICE_ROLE_KEY=

# Optional: canonical site URL for invite redirect links (defaults to request Origin)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
